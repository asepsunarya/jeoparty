# Example env for production (Coolify).
# Fill these in via Coolify environment variables / secrets.

# Public URLs
NEXT_PUBLIC_API_URL=https://api.jeoparty.example.com
NEXT_PUBLIC_WS_URL=https://api.jeoparty.example.com
CORS_ORIGIN=https://jeoparty.example.com

# Database
MONGO_URI=mongodb://mongo:27017/jeoparty

# Socket.IO scaling (recommended if backend has >1 replica)
REDIS_URL=redis://redis:6379

# S3 media storage (use real S3 or a private MinIO behind a proxy)
S3_REGION=us-east-1
S3_BUCKET=jeoparty-media
S3_ENDPOINT=https://s3.example.com
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
# MUST be reachable by browsers:
S3_PUBLIC_URL=https://cdn.jeoparty.example.com/jeoparty-media

# Optional AI
OPENAI_API_KEY=

# If using MinIO inside the compose (not recommended for public), set:
MINIO_ROOT_USER=jeoparty
MINIO_ROOT_PASSWORD=CHANGE_ME

