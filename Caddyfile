:80 {
  encode gzip

  # Backend (REST + Socket.IO)
  handle_path /api/* {
    reverse_proxy backend:4000
  }

  # Socket.IO handshake/transport lives under /socket.io
  handle_path /socket.io/* {
    reverse_proxy backend:4000
  }

  # Frontend (Next.js)
  handle {
    reverse_proxy frontend:3000
  }
}

